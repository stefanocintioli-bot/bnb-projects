# ─────────────────────────────────────────────────────────────
# BNB Chain DCA Agent — Environment Variables Template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to Git.
# ─────────────────────────────────────────────────────────────

# ── AI (Groq) ──────────────────────────────────────────────
# Free API key from https://console.groq.com
# Model used: llama3-8b-8192
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Telegram ───────────────────────────────────────────────
# 1. Create a bot via @BotFather on Telegram → get BOT_TOKEN
# 2. Get your personal CHAT_ID from @userinfobot on Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=123456789

# ── Wallet ─────────────────────────────────────────────────
# Use a TESTNET-ONLY wallet. Never put mainnet keys here.
# Export private key from MetaMask → Account Details → Export Private Key
WALLET_PRIVATE_KEY=0x_your_testnet_wallet_private_key_here

# ── Network ────────────────────────────────────────────────
# BSC Testnet RPC endpoint (public, no sign-up needed)
RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545/

# ── DCA Strategy ───────────────────────────────────────────
# How much tBNB to spend per cycle (e.g. 0.01 = ~$5 at $500/BNB)
DCA_AMOUNT_BNB=0.01

# Frequency: "daily" (every 24h) or "weekly" (every 7 days)
DCA_FREQUENCY=daily

# Target token to buy (testnet address)
# BUSD testnet:  0xeD24FC36d5Ee211Ea25A80239Fb8C4Cfd80f12Ee
# USDT testnet:  0x337610d27c682E347C9cD60BD4b3b107C9d34dDd
# CAKE testnet:  0x8516Fc284AEEaa0374E66037BD2309349FF728eA
TARGET_TOKEN=0xeD24FC36d5Ee211Ea25A80239Fb8C4Cfd80f12Ee

# ── AI Guardrail Thresholds ────────────────────────────────
# Guardrail 1: Skip if gas price (in Gwei) exceeds this value
GAS_THRESHOLD_GWEI=20

# Guardrail 2: Skip if token price moved more than X% in the last hour
PRICE_CHANGE_THRESHOLD=5.0

# Guardrail 3: Skip if the BNB/TOKEN pool has less than X BNB
MIN_LIQUIDITY_BNB=1.0
